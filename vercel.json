{
    "version": 2,
    "builds": [
      {
        "src": "dist/frontend-turisme-sostenible/browser/index.html",
        "use": "@vercel/static"
      }
    ],
    "headers": [
      {
        "source": "/(.*)",
        "headers": [
          {
            "key": "Content-Security-Policy",
            "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://unpkg.com; style-src 'self' 'unsafe-inline' https://unpkg.com;"
          }
        ]
      }
    ],
    "cleanUrls": true,
    "trailingSlash": false
  }